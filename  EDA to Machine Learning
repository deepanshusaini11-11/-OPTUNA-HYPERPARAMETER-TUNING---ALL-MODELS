        "import pandas as pd\n",
        "\n",
        "def clean_and_standardize_text(df):\n",
        "    df = df.copy()\n",
        "\n",
        "    # ---------- Column Groups ----------\n",
        "    title_case_cols = [\n",
        "        'ship_mode', 'segment', 'state', 'country',\n",
        "        'market', 'region', 'category', 'sub_category'\n",
        "    ]\n",
        "\n",
        "    upper_case_cols = ['product_id']\n",
        "    strip_only_cols = ['product_name']\n",
        "\n",
        "    # ---------- Standardization Maps ----------\n",
        "    standard_maps = {\n",
        "        'ship_mode': {\n",
        "            'standard class': 'Standard Class',\n",
        "            'std class': 'Standard Class',\n",
        "            'second class': 'Second Class',\n",
        "            'first class': 'First Class',\n",
        "            'same day': 'Same Day'\n",
        "        }\n",
        "    }\n",
        "\n",
        "    all_cols = title_case_cols + upper_case_cols + strip_only_cols\n",
        "    existing_cols = [col for col in all_cols if col in df.columns]\n",
        "\n",
        "    # ---------- Base Cleaning ----------\n",
        "    for col in existing_cols:\n",
        "        df[col] = (\n",
        "            df[col]\n",
        "            .astype(str)\n",
        "            .replace('nan', '')\n",
        "            .str.strip()\n",
        "            .str.lower()   # normalize first (IMPORTANT)\n",
        "        )\n",
        "\n",
        "    # ---------- Apply Standard Mappings ----------\n",
        "    for col, mapping in standard_maps.items():\n",
        "        if col in df.columns:\n",
        "            df[col] = df[col].replace(mapping)\n",
        "\n",
        "    # ---------- Apply Transformations ----------\n",
        "    for col in title_case_cols:\n",
        "        if col in df.columns:\n",
        "            df[col] = df[col].str.title()\n",
        "\n",
        "    for col in upper_case_cols:\n",
        "        if col in df.columns:\n",
        "            df[col] = df[col].str.upper()\n",
        "\n",
        "    # ---------- Optional: Unknown Handling ----------\n",
        "    for col in existing_cols:\n",
        "        df[col] = df[col].replace('', 'Unknown')\n",
        "\n",
        "    return df"
