        "import pandas as pd\n",
        "import numpy as np\n",
        "\n",
        "def advanced_missing_handler(df):\n",
        "    df = df.copy()\n",
        "\n",
        "    # ---------- Column Type Detection ----------\n",
        "    num_cols = df.select_dtypes(include=np.number).columns.tolist()\n",
        "    cat_cols = df.select_dtypes(include='object').columns.tolist()\n",
        "\n",
        "    # ---------- NUMERIC IMPUTATION ----------\n",
        "    for col in num_cols:\n",
        "        missing_pct = df[col].isnull().mean()\n",
        "\n",
        "        if missing_pct > 0:\n",
        "            # If highly skewed → median\n",
        "            if abs(df[col].skew()) > 1:\n",
        "                df[col] = df[col].fillna(df[col].median())\n",
        "\n",
        "            # If normal distribution → mean\n",
        "            else:\n",
        "                df[col] = df[col].fillna(df[col].mean())\n",
        "\n",
        "    # ---------- CATEGORICAL IMPUTATION ----------\n",
        "    for col in cat_cols:\n",
        "        missing_pct = df[col].isnull().mean()\n",
        "\n",
        "        if missing_pct > 0:\n",
        "            # Fill with mode (most frequent)\n",
        "            mode_val = df[col].mode(dropna=True)\n",
        "            if not mode_val.empty:\n",
        "                df[col] = df[col].fillna(mode_val[0])\n",
        "            else:\n",
        "                df[col] = df[col].fillna('Unknown')\n",
        "\n",
        "    # ---------- SPECIAL BUSINESS RULES ----------\n",
        "\n",
        "    # Example: Year column\n",
        "    if 'year' in df.columns:\n",
        "        df['year'] = pd.to_numeric(df['year'], errors='coerce')\n",
        "        df['year'] = df['year'].fillna(df['year'].mode()[0])\n",
        "\n",
        "    # Example: Sales should not be negative or null\n",
        "    if 'sales' in df.columns:\n",
        "        df['sales'] = pd.to_numeric(df['sales'], errors='coerce')\n",
        "        df['sales'] = df['sales'].fillna(df['sales'].median())\n",
        "        df.loc[df['sales'] < 0, 'sales'] = df['sales'].median()\n",
        "\n",
        "    # ---------- MISSING INDICATOR (VERY IMPORTANT) ----------\n",
        "    for col in df.columns:\n",
        "        if df[col].isnull().sum() > 0:\n",
        "            df[f'{col}_missing_flag'] = df[col].isnull().astype(int)\n",
        "\n",
        "    return df"
      ]
    },
