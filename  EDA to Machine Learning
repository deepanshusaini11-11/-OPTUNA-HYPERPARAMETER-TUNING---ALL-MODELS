      "source": [
        "import pandas as pd\n",
        "import numpy as np\n",
        "\n",
        "def data_quality_check(df):\n",
        "    report = {}\n",
        "\n",
        "    # ---------- Basic Info ----------\n",
        "    report['total_rows'] = df.shape[0]\n",
        "    report['total_columns'] = df.shape[1]\n",
        "    report['duplicate_rows'] = df.duplicated().sum()\n",
        "\n",
        "    # ---------- Missing Values ----------\n",
        "    report['missing_values'] = df.isnull().sum().to_dict()\n",
        "\n",
        "    # ---------- Data Type Summary ----------\n",
        "    report['data_types'] = df.dtypes.astype(str).to_dict()\n",
        "\n",
        "    # ---------- Helper Functions ----------\n",
        "    def safe_numeric(series):\n",
        "        return pd.to_numeric(series, errors='coerce')\n",
        "\n",
        "    def safe_string(series):\n",
        "        return series.astype(str).str.strip()\n",
        "\n",
        "    # ---------- Column-wise Checks ----------\n",
        "    checks = {}\n",
        "\n",
        "    # SALES\n",
        "    if 'sales' in df.columns:\n",
        "        sales = safe_numeric(df['sales'])\n",
        "        checks['invalid_sales'] = sales.isnull().sum()\n",
        "\n",
        "    # QUANTITY\n",
        "    if 'quantity' in df.columns:\n",
        "        qty = safe_numeric(df['quantity'])\n",
        "        checks['invalid_quantity_negative'] = (qty < 0).sum()\n",
        "\n",
        "    # DISCOUNT\n",
        "    if 'discount' in df.columns:\n",
        "        disc = safe_numeric(df['discount'])\n",
        "        checks['invalid_discount'] = ((disc < 0) | (disc > 1)).sum()\n",
        "\n",
        "    # PROFIT\n",
        "    if 'profit' in df.columns:\n",
        "        profit = safe_numeric(df['profit'])\n",
        "        checks['invalid_profit_null'] = profit.isnull().sum()\n",
        "\n",
        "    # SHIPPING COST\n",
        "    if 'shipping_cost' in df.columns:\n",
        "        ship_cost = safe_numeric(df['shipping_cost'])\n",
        "        checks['invalid_shipping_cost_negative'] = (ship_cost < 0).sum()\n",
        "\n",
        "    # YEAR\n",
        "    if 'year' in df.columns:\n",
        "        year = safe_numeric(df['year'])\n",
        "        checks['invalid_year'] = ((year < 2000) | (year > 2030)).sum()\n",
        "\n",
        "    # ---------- Object Column Checks ----------\n",
        "    object_cols = df.select_dtypes(include=['object']).columns\n",
        "\n",
        "    empty_string_checks = {}\n",
        "    for col in object_cols:\n",
        "        col_data = safe_string(df[col])\n",
        "        empty_string_checks[f'empty_{col}'] = (col_data == '').sum()\n",
        "\n",
        "    report['column_checks'] = checks\n",
        "    report['empty_string_checks'] = empty_string_checks\n",
        "\n",
        "    # ---------- Outlier Detection (IQR) ----------\n",
        "    numeric_cols = df.select_dtypes(include=np.number).columns\n",
        "    outliers = {}\n",
        "\n",
        "    for col in numeric_cols:\n",
        "        Q1 = df[col].quantile(0.25)\n",
        "        Q3 = df[col].quantile(0.75)\n",
        "        IQR = Q3 - Q1\n",
        "\n",
        "        lower = Q1 - 1.5 * IQR\n",
        "        upper = Q3 + 1.5 * IQR\n",
        "\n",
        "        outliers[col] = ((df[col] < lower) | (df[col] > upper)).sum()\n",
        "\n",
        "    report['outliers'] = outliers\n",
        "\n",
        "    return report"
      ]
    },
